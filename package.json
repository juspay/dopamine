{
  "name": "dopamine",
  "version": "2.0.0",
  "private": true,
  "description": "AI video retrieval and processing pipeline powered by Gemini — collects saved Instagram/YouTube content and extracts structured knowledge.",
  "license": "MIT",
  "author": "Sachin Sharma",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juspay/dopamine.git"
  },
  "bugs": {
    "url": "https://github.com/juspay/dopamine/issues"
  },
  "homepage": "https://github.com/juspay/dopamine#readme",
  "keywords": [
    "ai",
    "video",
    "pipeline",
    "gemini",
    "vertex-ai",
    "instagram",
    "youtube",
    "knowledge-extraction"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.0",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:run": "npm run build && node dist/pipeline/runner.js",
    "pipeline": "node dist/pipeline/runner.js",
    "youtube:auth": "node dist/sources/youtube/auth.js",
    "dashboard": "node dist/agents/dashboard.js",
    "merge-kb": "node dist/scripts/merge-knowledge-bases.js",
    "start": "node dist/server/webhook.js",
    "serve": "node dist/server/dashboard-server.js",
    "dashboard:data": "node dist/dashboard/data-builder.js",
    "dashboard:build": "npm run build && npm --prefix web install && npm --prefix web run build && npm run dashboard:data",
    "dev": "tsc --watch",
    "test": "node node_modules/vitest/vitest.mjs run",
    "commit": "cz",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@juspay/neurolink": "^9.59.5",
    "@types/compression": "^1.8.1",
    "compression": "^1.8.1",
    "dotenv": "^16.4.0",
    "execa": "^9.0.0",
    "express": "^4.19.0",
    "google-auth-library": "^10.7.0",
    "googleapis": "^173.0.0",
    "node-cron": "^3.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.15",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.1.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "semantic-release": "^24.2.9",
    "typescript": "^5.5.0",
    "vitest": "^4.1.2"
  }
}
