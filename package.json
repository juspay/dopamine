{
  "name": "dopamine",
  "version": "1.0.0",
  "private": true,
  "description": "AI video retrieval and processing pipeline powered by Gemini — collects saved Instagram/YouTube content and extracts structured knowledge.",
  "license": "MIT",
  "author": "Sachin Sharma",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juspay/dopamine.git"
  },
  "bugs": {
    "url": "https://github.com/juspay/dopamine/issues"
  },
  "homepage": "https://github.com/juspay/dopamine#readme",
  "keywords": ["ai", "video", "pipeline", "gemini", "vertex-ai", "instagram", "youtube", "knowledge-extraction"],
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@10.9.0",
  "files": ["dist", "README.md", "LICENSE"],
  "overrides": {
    "protobufjs": "^7.6.3",
    "@grpc/grpc-js": "^1.14.4",
    "@xmldom/xmldom": "^0.8.13"
  },
  "scripts": {
    "build": "tsc",
    "build:run": "npm run build && node dist/pipeline/runner.js",
    "pipeline": "node dist/pipeline/runner.js",
    "youtube:auth": "node dist/sources/youtube/auth.js",
    "dashboard": "node dist/agents/dashboard.js",
    "merge-kb": "node dist/scripts/merge-knowledge-bases.js",
    "start": "node dist/server/webhook.js",
    "serve": "node dist/server/dashboard-server.js",
    "dashboard:data": "node dist/dashboard/data-builder.js",
    "search:index": "node dist/search/indexer.js",
    "mcp:serve": "node dist/mcp/server.js",
    "digest": "node dist/agents/digest.js",
    "map:projects": "node dist/agents/project-mapper.js",
    "dashboard:build": "npm run build && npm --prefix web install && npm --prefix web run build && npm run dashboard:data",
    "dev": "tsc --watch",
    "test": "node node_modules/vitest/vitest.mjs run",
    "commit": "cz",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#dist\" \"#CHANGELOG.md\" \"#web\"",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": ["biome format --write --no-errors-on-unmatched"],
    "*.json": ["biome format --write --no-errors-on-unmatched"]
  },
  "dependencies": {
    "@juspay/neurolink": "^9.79.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/compression": "^1.8.1",
    "chrome-remote-interface": "^0.33.3",
    "compression": "^1.8.1",
    "dotenv": "^16.4.0",
    "execa": "^9.0.0",
    "express": "^5.2.1",
    "google-auth-library": "^10.7.0",
    "googleapis": "^173.0.0",
    "node-cron": "^3.0.3",
    "react": "^19.2.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/chrome-remote-interface": "^0.34.0",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.1.2",
    "commitizen": "^4.3.2",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "markdownlint-cli2": "^0.17.2",
    "semantic-release": "^24.2.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2"
  }
}
