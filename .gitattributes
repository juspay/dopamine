# Enforce LF line endings for all text files in the repo
* text=auto eol=lf

# Explicitly declare text files
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.py text eol=lf

# Declare binary files (never text-process)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp4 binary
*.mov binary
*.webp binary

# Generated / vendor — hide from git diff and linguist
dist/** -diff linguist-generated=true
web/dist/** -diff linguist-generated=true
package-lock.json -diff
