# ──────────────────────────────────────────────
# Instagram (used by Python scripts in scripts/)
# ──────────────────────────────────────────────
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=

# Saved-posts backend: "instagrapi" (default, private API) or "gallerydl"
# (cookie-auth fallback — a different request signature to use when instagrapi
# is soft-blocked). gallerydl needs cookies (below) instead of the password.
IG_COLLECTOR=instagrapi
# gallery-dl auth — set ONE when IG_COLLECTOR=gallerydl:
IG_COOKIES_FROM_BROWSER=          # chrome | firefox | safari | edge | brave …
IG_COOKIES_FILE=                  # or a Netscape cookies.txt path
# gallery-dl's /saved/all-posts covers only UNCATEGORIZED saves. Add named
# collections as comma-separated "Name/ID" pairs (or full URLs) to include them:
IG_SAVED_COLLECTIONS=             # e.g. Hhhh/18108476032316846,Chutiya/18015476110044023
IG_GDL_SLEEP=3.0-7.0             # gallery-dl --sleep-request range (seconds)
IG_GDL_TIMEOUT_SEC=2400          # hard cap for the whole gallery-dl run

# ──────────────────────────────────────────────
# Google Vertex AI (used by NeuroLink agents)
# ──────────────────────────────────────────────

# Service account credentials for Vertex AI
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Project and location for NeuroLink's Vertex provider
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=global

# These are used by scripts/run-pipeline.sh (launchd/cron context)
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Gemini model — override to switch models
# 3.x models require VERTEX_LOCATION=global
# 2.x models require VERTEX_LOCATION=us-central1
MODEL=gemini-3.1-flash-image-preview

# ──────────────────────────────────────────────
# Pipeline control
# ──────────────────────────────────────────────

# Run a subset of steps (0-indexed, END_STEP is exclusive)
# Full pipeline is 16 steps (0-15)
START_STEP=0
END_STEP=16

# Comma-separated categories that get full knowledge extraction
# KB_CATEGORIES=AI & Machine Learning,Tech & Coding,Business & Marketing,UI/UX Design

# Videos larger than this (bytes) use thumbnail instead of full video
# Set to 0 to always use thumbnails (recommended — avoids frame extraction limits)
VIDEO_SIZE_THRESHOLD=0

# ──────────────────────────────────────────────
# Server ports
# ──────────────────────────────────────────────
PORT=3000            # webhook + cron server (npm run start)
DASHBOARD_PORT=3001  # dashboard static server (npm run serve)

# ──────────────────────────────────────────────
# Optional: Langfuse observability
# ──────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ──────────────────────────────────────────────
# Multi-provider ingestion
# ──────────────────────────────────────────────
# Comma-separated sources to run. Default: instagram only.
SOURCES=instagram
# Download the YouTube mp4 only for videos at/under this duration (seconds); longer = transcript-only.
YT_DOWNLOAD_MAX_SECONDS=300
# YouTube Data API OAuth2 (Desktop app). REFRESH_TOKEN is written by `npm run youtube:auth`.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ──────────────────────────────────────────────
# Advanced tuning (optional — sensible defaults shown)
# ──────────────────────────────────────────────
# Frames sent to the classifier per video.
CLASSIFY_FRAMES=3
# Minimum visual_description length (chars) before knowledge is considered complete.
MIN_VISUAL_CHARS=200
# Concurrency for the ffprobe properties step.
PROPERTIES_CONCURRENCY=4
# Delay between AI requests (ms) — raise if you hit Vertex rate limits.
DELAY_MS=500
# Timeout for shelled-out commands like ffmpeg/ffprobe (ms).
COMMAND_TIMEOUT_MS=30000
# Timeout for URL-resolution fetches in the research step (ms).
URL_TIMEOUT_MS=12000
# How long sandbox dirs from the implementer step are kept (days).
SANDBOX_MAX_AGE_DAYS=7
# Log verbosity: error | warn | info | debug.
LOG_LEVEL=info
# Host the dashboard server binds to.
DASHBOARD_HOST=127.0.0.1
# Optional: reuse an existing instagrapi session id instead of logging in.
IG_SESSION_ID=

# ── Instagram fetch resilience (soft-block protection) ──
# Human-like delay between IG requests (seconds). Higher = gentler on rate limits.
IG_DELAY_MIN=3
IG_DELAY_MAX=7
# Per-request HTTP timeout for instagrapi (seconds).
IG_REQUEST_TIMEOUT_SEC=30
# Watchdog: abort the saved-feed fetch if it stalls this long (seconds). On an
# Instagram soft-block the private API hangs instead of erroring; this prevents a
# multi-hour hang that would also block the next scheduled run.
IG_FETCH_TIMEOUT_SEC=600
# Wall-clock caps (ms) the pipeline enforces on each Python scraper subprocess.
COLLECTOR_TIMEOUT_MS=660000   # metadata collection (11 min)
DOWNLOAD_TIMEOUT_MS=2700000   # video downloads incl. backlog (45 min)
