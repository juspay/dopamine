# ──────────────────────────────────────────────
# Instagram (used by Python scripts in scripts/)
# ──────────────────────────────────────────────
INSTAGRAM_USERNAME=user
INSTAGRAM_PASSWORD=

# ──────────────────────────────────────────────
# Google Vertex AI (used by NeuroLink agents)
# ──────────────────────────────────────────────

# Service account credentials for Vertex AI
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Project and location for NeuroLink's Vertex provider
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=global

# These are used by scripts/run-pipeline.sh (launchd/cron context)
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Gemini model — override to switch models
# 3.x models require VERTEX_LOCATION=global
# 2.x models require VERTEX_LOCATION=us-central1
MODEL=gemini-3.1-flash-image-preview

# ──────────────────────────────────────────────
# Pipeline control
# ──────────────────────────────────────────────

# Run a subset of steps (0-indexed, END_STEP is exclusive)
# Full pipeline is 16 steps (0-15)
START_STEP=0
END_STEP=16

# Comma-separated categories that get full knowledge extraction
# KB_CATEGORIES=AI & Machine Learning,Tech & Coding,Business & Marketing,UI/UX Design

# Videos larger than this (bytes) use thumbnail instead of full video
# Set to 0 to always use thumbnails (recommended — avoids frame extraction limits)
VIDEO_SIZE_THRESHOLD=0

# ──────────────────────────────────────────────
# Server ports
# ──────────────────────────────────────────────
PORT=3000            # webhook + cron server (npm run start)
DASHBOARD_PORT=3001  # dashboard static server (npm run serve)

# ──────────────────────────────────────────────
# Optional: Langfuse observability
# ──────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ──────────────────────────────────────────────
# Multi-provider ingestion
# ──────────────────────────────────────────────
# Comma-separated sources to run. Default: instagram only.
SOURCES=instagram
# Download the YouTube mp4 only for videos at/under this duration (seconds); longer = transcript-only.
YT_DOWNLOAD_MAX_SECONDS=300
# YouTube Data API OAuth2 (Desktop app). REFRESH_TOKEN is written by `npm run youtube:auth`.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
